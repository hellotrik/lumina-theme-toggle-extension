{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "watch",
        "tooltip": "esbuild watch（F5 默认构建）"
      }
    },
    {
      "label": "package",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/pack.sh", "--bump"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "icon": {
        "id": "package",
        "tooltip": "升版 + 打包 + 安装到 Cursor → dist/theme-toggle-<version>.vsix"
      }
    }
  ]
}
